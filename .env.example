# Postgres connection string (Railway Postgres plugin provides this automatically
# as ${{Postgres.DATABASE_URL}} if you add a Postgres service to the project)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Port the server binds to. Railway injects this automatically — do not hardcode it.
PORT=5000

# Optional: "production" enables JSON logs; anything else uses pretty-printed logs.
NODE_ENV=production

# Optional: pino log level (default: info)
LOG_LEVEL=info
